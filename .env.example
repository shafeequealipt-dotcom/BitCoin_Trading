# =============================================================================
# Trading Intelligence MCP — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your keys.
# NEVER commit .env to version control.
# =============================================================================

# --- Bybit ---
# Get keys at: https://testnet.bybit.com/app/user/api-management (testnet)
# Live keys at: https://www.bybit.com/app/user/api-management
BYBIT_API_KEY=
BYBIT_API_SECRET=

# --- Finnhub ---
# Get free key at: https://finnhub.io/register
FINNHUB_API_KEY=

# --- Reddit (PRAW) ---
# Create app at: https://www.reddit.com/prefs/apps
# Choose "script" type application
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=
REDDIT_PASSWORD=

# --- Telegram Alerts ---
# Create bot via @BotFather on Telegram, get chat ID via @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Anthropic (Claude Brain) ---
# Get key at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# --- MCP SSE Auth ---
# Generate a random token: python -c "import secrets; print(secrets.token_urlsafe(32))"
MCP_AUTH_TOKEN=

# --- OpenRouter (TIAS DeepSeek Analysis) ---
# Get key at: https://openrouter.ai/settings/keys
OPENROUTER_API_KEY=
